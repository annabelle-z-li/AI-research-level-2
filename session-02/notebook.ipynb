        "# Model 3: Zero-shot (uses whatever feeling labels YOU give it)\n",
        "model_zeroshot = pipeline(\"zero-shot-classification\", model=\"valhalla/distilbart-mnli-12-3\")\n",
        "print(\"Zero-shot model loaded!\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "S5eKpdXJxcV4"
      },
      "source": [
        "## Same Text, Three Different Feelings\n",
        "\n",
        "Run the same sentence through all three models and compare."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 9,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "7VMHTxG_xcV5",
        "outputId": "1cb967e0-aee2-4fc6-f082-43acdd22d045"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "BINARY: POSITIVE (87%)\n",
            "EMOTION: neutral (73%)\n",
            "\n",
            "YOUR LABELS:\n",
            "  regret: 45%\n",
            "  confusion: 34%\n",
            "  grief: 8%\n",
            "  hope: 7%\n",
            "  love: 4%\n",
            "  anxiety: 3%\n"
          ]
        }
      ],
      "source": [
        "text = \"I stayed up until 4am thinking about what I said to her. I keep replaying it.\"\n",
        "\n",
        "# Binary: POSITIVE or NEGATIVE\n",
        "r1 = model_binary(text)[0]\n",
        "print(f\"BINARY: {r1['label']} ({r1['score']:.0%})\")\n",
        "\n",
        "# Emotion: one of 7 emotions\n",
        "r2 = model_emotion(text)[0]\n",
        "print(f\"EMOTION: {r2['label']} ({r2['score']:.0%})\")\n",
        "\n",
        "# Zero-shot: your custom labels\n",
        "r3 = model_zeroshot(text, candidate_labels=[\"love\", \"grief\", \"anxiety\", \"hope\", \"regret\", \"confusion\"])\n",
        "print(f\"\\nYOUR LABELS:\")\n",
        "for label, score in zip(r3[\"labels\"], r3[\"scores\"]):\n",
        "    print(f\"  {label}: {score:.0%}\")"
      ]
    },

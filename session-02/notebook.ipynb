      "source": [
        "### Experiment 4: Design your own feeling labels\n",
        "\n",
        "**Try this:** The zero-shot model uses whatever labels you give it. What if you designed the perfect set of feelings for a specific kind of text?"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 13,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "aM1zRNMkxcV6",
        "outputId": "f7e14ea6-22b8-4be3-f388-3be33c81b93b"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "SELF-DOUBT (71%): \"I don't know why I even bother anymore. Nothing I do seems to matter.\"\n",
            "\n",
            "HOPE (52%): \"Dear future me, I hope you figured it out.\"\n",
            "\n",
            "NUMBNESS (28%): \"Today was actually okay. Not great, not terrible. Just okay.\"\n",
            "\n"
          ]
        }
      ],
      "source": [
        "# Design your own labels for a specific type of text\n",
        "# For example, labels for reading someone's diary:\n",
        "my_labels = [\"loneliness\", \"hope\", \"self-doubt\", \"determination\", \"numbness\", \"gratitude\"]\n",
        "\n",
        "texts = [\n",
        "    \"I don't know why I even bother anymore. Nothing I do seems to matter.\",\n",
        "    \"Dear future me, I hope you figured it out.\",\n",
        "    \"Today was actually okay. Not great, not terrible. Just okay.\",\n",
        "]\n",
        "\n",
        "for text in texts:\n",
        "    r = model_zeroshot(text, candidate_labels=my_labels)\n",
        "    top = r[\"labels\"][0]\n",
        "    score = r[\"scores\"][0]\n",
        "    print(f\"{top.upper()} ({score:.0%}): \\\"{text}\\\"\")\n",
        "    print()"
      ]
    },
